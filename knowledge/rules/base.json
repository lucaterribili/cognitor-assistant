{
  "rules": {
    "greeting": {
      "default": "greeting_response"
    },
    "farewell": {
      "default": "farewell_response"
    },
    "help": {
      "default": "help_response"
    },
    "ask_name": {
      "default": "ask_name_response"
    },
    "thank_you": {
      "default": "thank_you_response"
    },
    "compliment": {
      "default": "compliment_response"
    },
    "insult": {
      "default": "insult_response"
    },
    "bot_challenge": {
      "default": "bot_challenge_response"
    },
    "ask_city_touristic_information": {
      "conditions": [
        {
          "if": [
            {
              "slot": "LOCATION",
              "operator": "eq",
              "value": "Roma"
            }
          ],
          "response": "ask_city_touristic_information_roma_response"
        },
        {
          "if": [
            {
              "slot": "LOCATION",
              "operator": "eq",
              "value": "Milano"
            }
          ],
          "response": "ask_city_touristic_information_milano_response"
        },
        {
          "if": [
            {
              "slot": "LOCATION_UNSUPPORTED",
              "operator": "eq",
              "value": true
            }
          ],
          "response": "ask_location_unsupported_response"
        },
        {
          "if": [
            {
              "slot": "LOCATION",
              "operator": "not_filled"
            }
          ],
          "response": "ask_location_wait_response",
          "wait_for_slot": "LOCATION"
        }
      ],
      "default": "ask_location_wait_response"
    },
    "mood_great": {
      "default": "mood_great_response"
    },
    "mood_unhappy": {
      "default": "mood_unhappy_response"
    },
    "joke": {
      "default": "joke_response"
    },
    "weather_query": {
      "default": "weather_query_response"
    },
    "time_query": {
      "default": "time_query_response"
    },
    "date_query": {
      "default": "date_query_response"
    },
    "low_confidence_fallback": {
      "default": "low_confidence_fallback_response"
    },
    "introduce_user": {
      "conditions": [
        {
          "if": [
            {
              "slot": "PERSON",
              "operator": "filled"
            }
          ],
          "response": "introduce_user_response"
        },
        {
          "if": [
            {
              "slot": "PERSON",
              "operator": "not_filled"
            }
          ],
          "response": "introduce_user_response"
        }
      ],
      "default": "introduce_user_response"
    },
    "open_app": {
      "conditions": [
        {
          "if": [
            {
              "slot": "PRODUCT",
              "operator": "eq",
              "value": "WhatsApp"
            }
          ],
          "response": "open_app_whatsapp_response"
        },
        {
          "if": [
            {
              "slot": "PRODUCT",
              "operator": "eq",
              "value": "Telegram"
            }
          ],
          "response": "open_app_telegram_response"
        },
        {
          "if": [
            {
              "slot": "PRODUCT",
              "operator": "eq",
              "value": "Spotify"
            }
          ],
          "response": "open_app_spotify_response"
        },
        {
          "if": [
            {
              "slot": "PRODUCT",
              "operator": "eq",
              "value": "Chrome"
            }
          ],
          "response": "open_app_chrome_response"
        },
        {
          "if": [
            {
              "slot": "PRODUCT_UNSUPPORTED",
              "operator": "eq",
              "value": true
            }
          ],
          "response": "open_app_unsupported_response"
        },
        {
          "if": [
            {
              "slot": "PRODUCT",
              "operator": "not_filled"
            }
          ],
          "response": "open_app_wait_response",
          "wait_for_slot": "PRODUCT"
        }
      ],
      "default": "open_app_wait_response"
    }
  }
}
